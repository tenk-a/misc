{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "esupath: VC++ x64 Debug",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/vc-x64/Debug/esupath.exe",
      "args": [
        "--list",
        "--env"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "integratedTerminal",
      "preLaunchTask": "CMake: build VC++ x64 Debug"
    },
    {
      "name": "esupath: VC++ x64 Run",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/vc-x64/Debug/esupath.exe",
      "args": [
        "--list",
        "--env"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "integratedTerminal",
      "noDebug": true,
      "preLaunchTask": "CMake: build VC++ x64 Debug"
    },
    {
      "name": "esupath: VC++ Win32 Debug",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/vc-win32/Debug/esupath.exe",
      "args": [
        "--list",
        "--env"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "integratedTerminal",
      "preLaunchTask": "CMake: build VC++ Win32 Debug"
    }
  ]
}
